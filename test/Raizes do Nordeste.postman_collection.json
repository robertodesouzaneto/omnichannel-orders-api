  "item": [
    {
      "name": "T01 - Login válido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Validade status e Salva Token\", function () {",
              "    pm.response.to.have.status(200);",
              "    const jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"accessToken\", jsonData.token);",
              "});",
              "",
              "pm.test(\"Valida resposta da API\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.token).to.not.be.null;",
              "    pm.expect(jsonData.userId).to.not.be.null;",
              "    pm.expect(jsonData.name).to.eq('Administrador Master');",
              "    pm.expect(jsonData.role).to.eq('ADMIN');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"admin@raizes.com\",\r\n  \"password\": \"admin1234\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{apiUrl}}/auth/login",
          "host": [
            "{{apiUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
