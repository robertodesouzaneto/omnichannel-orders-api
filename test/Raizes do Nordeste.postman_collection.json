              "});\r",
              "\r",
              "pm.test(\"Valida resposta da API\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.not.be.null;\r",
              "    pm.expect(jsonData.customerId).to.not.be.null;\r",
              "    pm.expect(jsonData.customerName).to.eq('Cliente da Silva');\r",
              "    pm.expect(jsonData.status).to.eq('PENDING');\r",
              "    pm.expect(jsonData.total).to.eq(77.80);\r",
              "    pm.expect(jsonData.items).to.have.length(2);\r",
